---
import type { CollectionEntry } from 'astro:content';
import PageLayout from './PageLayout.astro';
import TableOfContents from '../components/TableOfContents.tsx';
import PostHeader from '../components/blog/PostHeader.astro';
import RelatedPosts from '../components/blog/RelatedPosts.astro';
import PostNavigation from '../components/blog/PostNavigation.astro';
import ErrorBoundary from '../components/ErrorBoundary.tsx';

type Props = CollectionEntry<'blog'>['data'] & {
    headings?: any[];
    prevPost?: CollectionEntry<'blog'> | null;
    nextPost?: CollectionEntry<'blog'> | null;
    recentPosts?: CollectionEntry<'blog'>[];
};

const {
    title,
    description,
    date,
    updatedDate,
    headings = [],
    tags = [],
    heroImage,
    prevPost = null,
    nextPost = null,
    recentPosts = [],
} = Astro.props;
---

<PageLayout title={title} description={description} image={heroImage}>
    <div
        class="xl:grid xl:grid-cols-[1fr_260px] lg:gap-12 xl:gap-20 items-start"
    >
        <article
            class="prose prose-lg prose-invert prose-zinc max-w-none text-zinc-300 leading-relaxed min-w-0 pb-16"
        >
            <PostHeader
                title={title}
                date={date}
                updatedDate={updatedDate}
                tags={tags}
            />

            <!-- Mobile inline TOC (collapsible) -->
            {
                headings.length > 0 && (
                    <div class="xl:hidden mb-10 border border-zinc-800/50 rounded-xl px-5 py-4 not-prose">
                        <ErrorBoundary client:load>
                            <TableOfContents
                                headings={headings}
                                isMobile={true}
                                client:media="(max-width: 1279px)"
                            />
                        </ErrorBoundary>
                    </div>
                )
            }

            <!-- Main Content Slot -->
            <slot />

            <!-- See Also Section -->
            <RelatedPosts posts={recentPosts} />

            <!-- Post Navigation -->
            <PostNavigation prevPost={prevPost} nextPost={nextPost} />
        </article>

        <!-- Desktop sticky TOC -->
        {
            headings.length > 0 && (
                <aside class="hidden xl:block sticky top-24 shrink-0 -mt-2">
                    <ErrorBoundary client:load>
                        <TableOfContents
                            headings={headings}
                            client:media="(min-width: 1280px)"
                        />
                    </ErrorBoundary>
                </aside>
            )
        }
    </div>

    <script src="../scripts/mermaid.ts"></script>
</PageLayout>
