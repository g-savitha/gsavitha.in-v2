  <!-- Tools -->
  <div>
    <h2 class="text-2xl font-bold font-outfit text-white mb-8 tracking-tight">
      Tech Stack
    </h2>
    <dl class="grid gap-y-0 text-sm">
      {
        tools.map(({ emoji, label, value }) => (
          <div class="flex flex-col sm:flex-row sm:gap-6 border-b border-zinc-700/50 py-3.5 last:border-0">
            <dt class="text-zinc-100 font-mono text-xs uppercase tracking-widest w-40 shrink-0 pt-0.5 flex items-center gap-2">
              <>
                <span>{emoji}</span>
                <span>{label}</span>
              </>
            </dt>
            <dd class="text-zinc-200">{value}</dd>
          </div>
        ))
      }
    </dl>
  </div>

  <hr class="border-zinc-700/50 my-16" />

  <!-- Endorsements -->
  <div>
    <h2 class="text-2xl font-bold font-outfit text-white mb-3 tracking-tight">
      Testimonials
