---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import ProfileImage from '../assets/image.png';
import FormattedDate from '../components/FormattedDate.astro';
import { User, FileText, PenBox } from 'lucide-astro';
import { USER_NAME } from '../consts';

import { getRecentPosts, filterDrafts } from '../utils/content';

const allPosts = await getCollection('blog');
const posts = getRecentPosts(filterDrafts(allPosts), undefined, 5);

const papers = (await getCollection('papers'))
    .sort(
        (a, b) => (b.data.date?.valueOf() || 0) - (a.data.date?.valueOf() || 0),
    )
    .slice(0, 5);
---

<PageLayout>
    <!-- Hero Profile Section -->
    <section
        class="flex flex-col-reverse sm:flex-row gap-8 sm:gap-12 items-start justify-between mb-20"
    >
        <div class="flex-1">
            <h1
                class="text-4xl sm:text-[2.75rem] font-bold tracking-tight text-white mb-3 font-outfit"
            >
                Hi, I'm Savitha!
            </h1>
            <p class="text-zinc-400 text-sm font-mono mb-6 tracking-wide">
                Senior Software Engineer · TypeScript · React · Node.js · AWS
            </p>
            <div
                class="prose prose-lg prose-invert prose-zinc text-zinc-300 leading-relaxed mb-8 max-w-2xl"
            >
                <p>
                    I build full-stack web applications and internal developer
                    tooling. Currently exploring <span
                        class="text-white font-medium">distributed systems</span
                    >, <span class="text-white font-medium">MCP</span>, and <span
                        class="text-white font-medium"
                        >AI-powered workflows</span
                    >.
                </p>
            </div>

            <div class="flex flex-wrap gap-4">
                <a
                    href="/about"
                    class="px-5 py-2.5 flex items-center gap-2.5 bg-zinc-800/40 hover:bg-zinc-800 border border-zinc-700/80 rounded-xl text-[0.95rem] font-medium text-zinc-200 hover:text-white transition-all shadow-sm group"
                >
                    <User
                        class="w-4 h-4 text-zinc-400 group-hover:text-primary transition-colors"
                    /> Know more
                </a>
                <!-- <a
                    href="/rss.xml"
                    class="px-5 py-2.5 flex items-center gap-2.5 bg-zinc-800/40 hover:bg-zinc-800 border border-zinc-700/80 rounded-xl text-[0.95rem] font-medium text-zinc-200 hover:text-white transition-all shadow-sm group"
                >
                    <Mail
                        class="w-4 h-4 text-zinc-400 group-hover:text-primary transition-colors"
                    /> Email Newsletter
                </a> -->
            </div>
        </div>

        <div class="relative w-32 h-32 sm:w-48 sm:h-48 shrink-0 group">
            <div
                class="absolute inset-0 bg-primary/20 rounded-full blur-xl group-hover:bg-primary/40 group-hover:blur-2xl transition-all duration-700 -z-10 animate-pulse"
            >
            </div>

            <div
                class="w-full h-full rounded-full p-1 bg-gradient-to-tr from-primary/10 via-primary/30 to-primary/10 border-2 border-primary/20 backdrop-blur-sm shadow-xl shadow-primary/20 overflow-hidden transform transition-all duration-500 group-hover:scale-[1.05] group-hover:-translate-y-2 group-hover:rotate-3"
            >
                <Image
                    src={ProfileImage}
                    alt="Profile"
                    class="w-full h-full object-cover rounded-full transition-transform duration-700 group-hover:scale-110 group-hover:rotate-[-3deg]"
                />
            </div>

            <div
                class="absolute -top-4 -right-4 w-8 h-8 bg-primary/30 rounded-full blur-md animate-ping"
                style="animation-duration: 3s;"
            >
            </div>
            <div
                class="absolute -bottom-4 -left-2 w-6 h-6 bg-primary/40 rounded-full blur-sm animate-pulse"
                style="animation-duration: 4s;"
            >
            </div>
        </div>
    </section>

    <!-- Blog Section -->
    <section class="mb-20">
        <div class="mb-8">
            <a href="/blog" class="inline-flex items-center gap-3 group/title">
                <h2
                    class="text-3xl font-bold font-outfit text-white mb-2 flex items-center gap-3 group-hover/title:text-primary transition-colors"
                >
                    <PenBox class="w-7 h-7 text-zinc-500 group-hover/title:text-primary transition-colors" /> Writings
                </h2>
            </a>
            <p class="text-zinc-400">Things that I've written recently</p>
        </div>

        <ul class="flex flex-col">
            {
                posts.map((post) => (
                    <li class="border-b border-zinc-800/80 last:border-0">
                        <a
                            href={`/blog/${post.id}`}
                            class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-6 py-3 -mx-3 px-3 rounded-lg hover:bg-zinc-800/60 transition-colors group"
                        >
                            <span class="text-zinc-400 group-hover:text-zinc-200 text-sm font-mono shrink-0 w-32 transition-colors">
                                <FormattedDate date={post.data.date} />
                            </span>
                            <span class="text-primary group-hover:text-primary-hover font-medium font-outfit transition-colors text-lg line-clamp-2 flex-1">
                                {post.data.title}
                            </span>
                            <div class="hidden sm:flex text-zinc-500 opacity-0 group-hover:opacity-100 transition-all duration-300 shrink-0 transform translate-x-[-10px] group-hover:translate-x-0 items-center justify-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                            </div>
                        </a>
                    </li>
                ))
            }
        </ul>
    </section>

    <!-- Papers Section -->
    <section>
        <div class="mb-8">
            <a href="/papers" class="inline-flex items-center gap-3 group/title">
                <h2
                    class="text-3xl font-bold font-outfit text-white mb-2 flex items-center gap-3 group-hover/title:text-primary transition-colors"
                >
                    <FileText class="w-7 h-7 text-zinc-500 group-hover/title:text-primary transition-colors" /> Research Notes
                </h2>
            </a>
            <p class="text-zinc-400">Things that I've read recently</p>
        </div>

        <ul class="flex flex-col">
            {
                papers.map((paper) => (
                    <li class="border-b border-zinc-800/80 last:border-0">
                        <a
                            href={paper.data.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-6 py-3 -mx-3 px-3 rounded-lg hover:bg-zinc-800/60 transition-colors group"
                        >
                            <span class="text-zinc-400 group-hover:text-zinc-200 text-sm font-mono shrink-0 w-32 transition-colors">
                                {paper.data.date ? (
                                    <FormattedDate date={paper.data.date} />
                                ) : (
                                    'Recent'
                                )}
                            </span>
                            <span class="text-primary group-hover:text-primary-hover font-medium font-outfit transition-colors text-lg line-clamp-2 flex-1">
                                {paper.data.title}
                            </span>
                            <div class="hidden sm:flex text-zinc-500 opacity-0 group-hover:opacity-100 transition-all duration-300 shrink-0 transform translate-x-[-10px] group-hover:translate-x-0 items-center justify-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                                    <polyline points="15 3 21 3 21 9" />
                                    <line x1="10" y1="14" x2="21" y2="3" />
                                </svg>
                            </div>
                        </a>
                    </li>
                ))
            }
        </ul>
    </section>
</PageLayout>
