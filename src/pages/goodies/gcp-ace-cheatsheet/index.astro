---
import PageLayout from '../../../layouts/PageLayout.astro';
import PdfViewer from '../../../components/PdfViewer.astro';
import { SITE_TITLE } from '../../../consts';
---

<PageLayout
    title={`GCP ACE Cheat Sheet | ${SITE_TITLE}`}
    description="A visual mind map for the Google Cloud Associate Cloud Engineer exam."
>
    <div class="mb-4 sm:mb-6">
        <a
            href="/goodies"
            class="text-sm text-zinc-500 hover:text-primary transition-colors flex items-center gap-1 mb-3"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-3.5 h-3.5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <path d="M15 18l-6-6 6-6"></path>
            </svg>
            Goodies
        </a>
        
        <PdfViewer 
            url="/gcp-ace-cheatsheet.pdf"
            title="GCP ACE Cheat Sheet"
            downloadFilename="gcp-ace-cheatsheet.pdf"
        >
            <p slot="description" class="text-zinc-400 max-w-xl text-sm">
                A visual mind map covering all key topics for the Google
                Cloud Associate Cloud Engineer exam.
            </p>
        </PdfViewer>
    </div>
</PageLayout>
