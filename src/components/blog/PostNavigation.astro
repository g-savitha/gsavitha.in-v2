---
import type { CollectionEntry } from 'astro:content';

interface Props {
    prevPost?: CollectionEntry<'blog'> | null;
    nextPost?: CollectionEntry<'blog'> | null;
}

const { prevPost, nextPost } = Astro.props;
---

{
    (prevPost || nextPost) && (
        <div class="mt-24 pt-8 border-t border-zinc-800/80 flex flex-col sm:flex-row items-center justify-between gap-8 not-prose">
            {prevPost ? (
                <a
                    href={`/blog/${prevPost.id}`}
                    class="flex items-center gap-3 text-primary hover:text-primary-hover transition-colors group w-full sm:w-1/2"
                >
                    <div class="w-10 h-10 rounded-full bg-zinc-800/40 border border-zinc-700/50 flex items-center justify-center group-hover:bg-zinc-800 transition-colors shrink-0">
                        <span class="text-xl text-zinc-400 group-hover:text-white transition-colors">
                            ←
                        </span>
                    </div>
                    <span class="font-medium text-[1.05rem] truncate">
                        {prevPost.data.title}
                    </span>
                </a>
            ) : (
                <div class="hidden sm:block sm:w-1/2" />
            )}

            {nextPost ? (
                <a
                    href={`/blog/${nextPost.id}`}
                    class="flex items-center gap-3 text-primary hover:text-primary-hover transition-colors group w-full sm:w-1/2 text-right justify-end ml-auto"
                >
                    <span class="font-medium text-[1.05rem] truncate">
                        {nextPost.data.title}
                    </span>
                    <div class="w-10 h-10 rounded-full bg-zinc-800/40 border border-zinc-700/50 flex items-center justify-center group-hover:bg-zinc-800 transition-colors shrink-0">
                        <span class="text-xl text-zinc-400 group-hover:text-white transition-colors">
                            →
                        </span>
                    </div>
                </a>
            ) : (
                <div class="hidden sm:block sm:w-1/2" />
            )}
        </div>
    )
}
