---
import FormattedDate from '../FormattedDate.astro';

interface Props {
    title: string;
    date: Date;
    updatedDate?: Date;
    tags?: string[];
}

const { title, date, updatedDate, tags = [] } = Astro.props;
---

<div class="mb-12 border-b border-zinc-800/80 pb-10 not-prose">
    <a
        href="/blog"
        class="inline-flex items-center gap-1 text-sm text-zinc-500 hover:text-primary transition-colors mb-6"
    >
        <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-3.5 h-3.5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <path d="M15 18l-6-6 6-6"></path>
        </svg>
        All Posts
    </a>
    <h1
        class="text-4xl sm:text-[2.75rem] font-bold tracking-tight text-white mb-6 font-outfit leading-tight"
    >
        {title}
    </h1>

    <div
        class="flex flex-wrap items-center gap-4 text-[0.95rem] text-zinc-400 font-medium mb-6"
    >
        <FormattedDate date={date} />
        {
            updatedDate && (
                <span>
                    (Updated <FormattedDate date={updatedDate} />)
                </span>
            )
        }
    </div>

    {
        tags && tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4">
                {tags.map((tag: string) => (
                    <a
                        href={`/tags/${tag}`}
                        class="px-3 py-1 bg-zinc-900/50 hover:bg-zinc-800 border border-zinc-800 rounded-md text-[0.85rem] text-zinc-300 font-medium transition-colors"
                    >
                        {tag}
                    </a>
                ))}
            </div>
        )
    }
</div>
