---
import { USER_FULL_NAME } from '../consts';

const today = new Date();
---

<footer class="mt-auto py-10">
    <div class="px-6 lg:px-12">
        <div
            class="border-t border-zinc-800/80 pt-8 flex items-center justify-between"
        >
            <p class="text-sm text-zinc-500">
                &copy; {today.getFullYear()} {USER_FULL_NAME}. All rights reserved.
            </p>
            <p class="text-sm text-zinc-600 font-medium">Built with Astro</p>
        </div>
    </div>
</footer>
