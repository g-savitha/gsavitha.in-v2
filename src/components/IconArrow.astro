---
/**
 * IconArrow component renders a consistent external link or navigation arrow.
 */
interface Props {
    class?: string;
}

const { class: className = "w-4 h-4" } = Astro.props;
---

<svg
    xmlns="http://www.w3.org/2000/svg"
    class={`${className} shrink-0 transition-colors`}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
>
    <path d="M9 18l6-6-6-6" />
</svg>
