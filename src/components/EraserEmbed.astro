---
interface Props {
  url: string;
  height?: string;
  title?: string;
}

const { url, height = "500px", title = "Eraser.io Architecture Diagram" } = Astro.props;

// Ensure it's the embed URL if they pasted a normal one
const embedUrl = url.includes('?') ? `${url}&embed=true` : `${url}?embed=true`;
---

<div class="my-8 rounded-xl overflow-hidden border border-zinc-800 shadow-lg w-full bg-zinc-900/50">
  <iframe 
    src={embedUrl} 
    title={title}
    style={`height: ${height}; width: 100%; border: none;`}
    loading="lazy"
    allowfullscreen
  />
</div>
