---
import { SITE_TITLE } from '../consts';
import ThemePicker from './ThemePicker.tsx';
import {
	BookOpen,
	PenTool,
	User,
	Award,
	Sparkles,
	Twitter,
	Github,
	Rss,
	Linkedin,
	Terminal,
	Mail,
} from 'lucide-astro';

const pathname = Astro.url.pathname;
function isActive(path: string) {
	if (path === '/' && pathname === '/') return true;
	if (path !== '/' && pathname.startsWith(path)) return true;
	return false;
}
---

<aside
	class="lg:w-64 xl:w-72 lg:shrink-0 bg-zinc-900 lg:h-screen lg:sticky lg:top-0 lg:flex lg:flex-col lg:justify-between py-6 px-6 lg:py-10 hidden relative before:hidden lg:before:block before:absolute before:inset-y-8 before:right-0 before:w-px before:bg-zinc-800/80"
>
	<!-- Desktop Sidebar -->
	<div class="space-y-10">
		<div class="flex items-center gap-3 px-1">
			<!-- <div
				class="w-6 h-6 rounded bg-primary flex items-center justify-center shadow-inner shrink-0"
			>
				<span class="w-2.5 h-2.5 bg-[#141416] rounded-sm transform rotate-45"
				></span>
			</div> -->
			<a
				href="/"
				class={`text-2xl font-bold pb-1 font-sacramento text-white hover:text-primary transition-colors flex-grow truncate inline-block ${pathname === '/' ? 'typing-effect' : ''}`}
				>{SITE_TITLE}</a
			>
			<ThemePicker client:load />
		</div>

		<div class="px-1">
			<h3 class="text-sm font-bold text-zinc-100 mb-3">About Me</h3>
			<p class="text-[0.95rem] text-zinc-400 leading-relaxed pr-2">
				I'm <a href="/"><span class="text-primary font-medium">Savitha</span></a
				>, a passionate and curious developer from India. Welcome to my digital
				garden 🌱.
			</p>
		</div>

		<nav>
			<ul class="space-y-2 font-medium text-[0.95rem] text-zinc-300">
				<li>
					<a
						href="/blog"
						class={`flex items-center gap-3 px-4 py-2.5 -mx-4 rounded-xl transition-colors hover:bg-zinc-800/40 group ${isActive('/blog') ? 'text-primary bg-zinc-800/30' : 'hover:text-primary'}`}
					>
						<PenTool
							class={`w-5 h-5 transition-colors ${isActive('/blog') ? 'text-primary' : 'text-zinc-500 group-hover:text-primary'}`}
						/>
						Blog
					</a>
				</li>
				<li>
					<a
						href="/papers"
						class={`flex items-center gap-3 px-4 py-2.5 -mx-4 rounded-xl transition-colors hover:bg-zinc-800/40 group ${isActive('/papers') ? 'text-primary bg-zinc-800/30' : 'hover:text-primary'}`}
					>
						<BookOpen
							class={`w-5 h-5 transition-colors ${isActive('/papers') ? 'text-primary' : 'text-zinc-500 group-hover:text-primary'}`}
						/>
						Notes
					</a>
				</li>
				<li>
					<a
						href="/certifications"
						class={`flex items-center gap-3 px-4 py-2.5 -mx-4 rounded-xl transition-colors hover:bg-zinc-800/40 group ${isActive('/certifications') ? 'text-primary bg-zinc-800/30' : 'hover:text-primary'}`}
					>
						<Award
							class={`w-5 h-5 transition-colors ${isActive('/certifications') ? 'text-primary' : 'text-zinc-500 group-hover:text-primary'}`}
						/>
						Certifications
					</a>
				</li>
				<li>
					<a
						href="/goodies"
						class={`flex items-center gap-3 px-4 py-2.5 -mx-4 rounded-xl transition-colors hover:bg-zinc-800/40 group ${isActive('/goodies') ? 'text-primary bg-zinc-800/30' : 'hover:text-primary'}`}
					>
						<Sparkles
							class={`w-5 h-5 transition-colors ${isActive('/goodies') ? 'text-primary' : 'text-zinc-500 group-hover:text-primary'}`}
						/>
						Goodies
					</a>
				</li>
				<li>
					<a
						href="/about"
						class={`flex items-center gap-3 px-4 py-2.5 -mx-4 rounded-xl transition-colors hover:bg-zinc-800/40 group ${isActive('/about') ? 'text-primary bg-zinc-800/30' : 'hover:text-primary'}`}
					>
						<User
							class={`w-5 h-5 transition-colors ${isActive('/about') ? 'text-primary' : 'text-zinc-500 group-hover:text-primary'}`}
						/>
						About Me
					</a>
				</li>
			</ul>
		</nav>
	</div>

	<div class="mt-12 lg:mt-0 px-1">
		<h3 class="text-sm font-bold text-zinc-100 mb-4">Stay Connected</h3>
		<ul class="space-y-2 text-[0.95rem] text-zinc-400">
			<li>
				<a
					href="https://twitter.com/gsavitha_"
					class="flex items-center gap-3 px-3 py-2 -mx-3 rounded-lg transition-colors hover:bg-zinc-800/40 hover:text-primary group"
				>
					<Twitter
						class="w-4 h-4 text-zinc-500 group-hover:text-primary transition-colors"
					/> Twitter / X
				</a>
			</li>
			<li>
				<a
					href="https://github.com/g-savitha"
					class="flex items-center gap-3 px-3 py-2 -mx-3 rounded-lg transition-colors hover:bg-zinc-800/40 hover:text-primary group"
				>
					<Github
						class="w-4 h-4 text-zinc-500 group-hover:text-primary transition-colors"
					/> GitHub
				</a>
			</li>
			<li>
				<a
					href="https://www.linkedin.com/in/g-savitha/"
					class="flex items-center gap-3 px-3 py-2 -mx-3 rounded-lg transition-colors hover:bg-zinc-800/40 hover:text-primary group"
				>
					<Linkedin
						class="w-4 h-4 text-zinc-500 group-hover:text-primary transition-colors"
					/> LinkedIn
				</a>
			</li>
			<li>
				<a
					href="https://takeuforward.org/profile/gsavitha"
					class="flex items-center gap-3 px-3 py-2 -mx-3 rounded-lg transition-colors hover:bg-zinc-800/40 hover:text-primary group"
				>
					<Terminal
						class="w-4 h-4 text-zinc-500 group-hover:text-primary transition-colors"
					/> TakeUForward
				</a>
			</li>
			<li>
				<a
					href="mailto:gsavitha@protonmail.com"
					class="flex items-center gap-3 px-3 py-2 -mx-3 rounded-lg transition-colors hover:bg-zinc-800/40 hover:text-primary group"
				>
					<Mail
						class="w-4 h-4 text-zinc-500 group-hover:text-primary transition-colors"
					/> Email
				</a>
			</li>
			<li>
				<a
					href="/rss.xml"
					class="flex items-center gap-3 px-3 py-2 -mx-3 rounded-lg transition-colors hover:bg-zinc-800/40 hover:text-primary group"
				>
					<Rss
						class="w-4 h-4 text-zinc-500 group-hover:text-primary transition-colors"
					/> RSS Feed
				</a>
			</li>
		</ul>
	</div>
</aside>

<!-- Mobile Header -->
<div
	class="lg:hidden flex items-center justify-between p-4 border-b border-zinc-800 bg-zinc-900/60 backdrop-blur-md sticky top-0 z-40 shadow-sm"
>
	<div class="flex items-center gap-3 shrink-0">
		<a href="/" class="font-bold text-zinc-100 flex items-center gap-2">
			<span
				class={`truncate max-w-[200px] font-sacramento text-2xl pt-1 pr-1 ${pathname === '/' ? 'typing-effect' : ''}`}
				>{SITE_TITLE}</span
			>
		</a>
	</div>
	<div class="flex items-center gap-3 shrink-0">
		<ThemePicker client:load />
		<button
			id="mobile-menu-btn"
			aria-label="Open menu"
			aria-expanded="false"
			class="w-8 h-8 flex items-center justify-center text-zinc-400 hover:text-white hover:bg-zinc-800 rounded-lg transition-colors"
		>
			<svg
				id="hamburger-icon"
				xmlns="http://www.w3.org/2000/svg"
				class="w-5 h-5"
				fill="none"
				viewBox="0 0 24 24"
				stroke="currentColor"
				stroke-width="2"
			>
				<line x1="3" y1="6" x2="21" y2="6"></line>
				<line x1="3" y1="12" x2="21" y2="12"></line>
				<line x1="3" y1="18" x2="21" y2="18"></line>
			</svg>
			<svg
				id="close-icon"
				xmlns="http://www.w3.org/2000/svg"
				class="w-5 h-5 hidden"
				fill="none"
				viewBox="0 0 24 24"
				stroke="currentColor"
				stroke-width="2"
			>
				<line x1="18" y1="6" x2="6" y2="18"></line>
				<line x1="6" y1="6" x2="18" y2="18"></line>
			</svg>
		</button>
	</div>
</div>
<!-- Mobile Drawer -->
<div
	id="mobile-drawer"
	class="lg:hidden hidden border-b border-zinc-800 bg-zinc-900/95 backdrop-blur sticky top-[57px] z-30 px-4 py-3 flex flex-col gap-1"
>
	<a
		href="/blog"
		class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-zinc-300 hover:text-primary hover:bg-zinc-800/50 transition-colors group"
	>
		<PenTool
			class="w-4 h-4 text-zinc-500 group-hover:text-primary transition-colors shrink-0"
		/>Blog
	</a>
	<a
		href="/papers"
		class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-zinc-300 hover:text-primary hover:bg-zinc-800/50 transition-colors group"
	>
		<BookOpen
			class="w-4 h-4 text-zinc-500 group-hover:text-primary transition-colors shrink-0"
		/>Notes
	</a>
	<a
		href="/certifications"
		class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-zinc-300 hover:text-primary hover:bg-zinc-800/50 transition-colors group"
	>
		<Award
			class="w-4 h-4 text-zinc-500 group-hover:text-primary transition-colors shrink-0"
		/>Certifications
	</a>
	<a
		href="/goodies"
		class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-zinc-300 hover:text-primary hover:bg-zinc-800/50 transition-colors group"
	>
		<Sparkles
			class="w-4 h-4 text-zinc-500 group-hover:text-primary transition-colors shrink-0"
		/>Goodies
	</a>
	<a
		href="/about"
		class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-zinc-300 hover:text-primary hover:bg-zinc-800/50 transition-colors group"
	>
		<User
			class="w-4 h-4 text-zinc-500 group-hover:text-primary transition-colors shrink-0"
		/>About Me
	</a>
</div>

<script>
	const btn = document.getElementById('mobile-menu-btn');
	const drawer = document.getElementById('mobile-drawer');
	const hamburgerIcon = document.getElementById('hamburger-icon');
	const closeIcon = document.getElementById('close-icon');

	btn?.addEventListener('click', () => {
		const isOpen = !drawer?.classList.contains('hidden');
		drawer?.classList.toggle('hidden', isOpen);
		hamburgerIcon?.classList.toggle('hidden', !isOpen);
		closeIcon?.classList.toggle('hidden', isOpen);
		btn.setAttribute('aria-expanded', String(!isOpen));
	});

	// Close drawer when a link is clicked
	drawer?.querySelectorAll('a').forEach((link) => {
		link.addEventListener('click', () => {
			drawer.classList.add('hidden');
			hamburgerIcon?.classList.remove('hidden');
			closeIcon?.classList.add('hidden');
			btn?.setAttribute('aria-expanded', 'false');
		});
	});
</script>

<style>
	@keyframes typing-reveal {
		0% {
			clip-path: inset(0 100% 0 0);
		}
		100% {
			clip-path: inset(
				0 -20% 0 0
			); /* -20% to avoid clipping cursive flourishes */
		}
	}
	.typing-effect {
		animation: typing-reveal 1.8s cubic-bezier(0.2, 0, 0.2, 1) 0.3s both;
	}
</style>
