---
/**
 * FormattedDate component takes a Date object and renders it in a human-readable format.
 * It also includes a machine-readable datetime attribute for SEO/accessibility.
 */
interface Props {
	date: Date;
}

const { date } = Astro.props;
---

<time datetime={date.toISOString()}>
	{
		date.toLocaleDateString('en-us', {
			year: 'numeric',
			month: 'short',
			day: 'numeric',
		})
	}
</time>
